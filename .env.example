# =============================================================================
# Azure AI Content Safety - Capital Markets Demo
# =============================================================================
# Copy this file to .env and fill in your credentials

# ---------------------------------------------------------------------------
# Azure AI Content Safety
# ---------------------------------------------------------------------------
CONTENT_SAFETY_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
CONTENT_SAFETY_API_KEY=<your-content-safety-api-key>
CONTENT_SAFETY_API_VERSION=2024-09-01

# ---------------------------------------------------------------------------
# Azure AI Foundry (OpenAI / Model Endpoint)
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-foundry-project>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure Foundry Project details
AZURE_FOUNDRY_PROJECT_NAME=<your-foundry-project-name>
AZURE_FOUNDRY_RESOURCE_GROUP=<your-resource-group>
AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# ---------------------------------------------------------------------------
# Microsoft Entra ID (for Managed Identity / RBAC demo)
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>

# ---------------------------------------------------------------------------
# Azure Resource Manager (for Foundry Control Plane API)
# ---------------------------------------------------------------------------
ARM_ENDPOINT=https://management.azure.com
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services>.cognitiveservices.azure.com/

# ---------------------------------------------------------------------------
# Backend Server
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# Demo Configuration
# ---------------------------------------------------------------------------
DEMO_MODE=true
DEMO_SIMULATE_LATENCY=false
LOG_LEVEL=INFO
